    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "@nestjs/core": "^11.0.1"
  },
